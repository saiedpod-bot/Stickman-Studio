# ============================================================
#  Stickman Studio — environment configuration
#  Copy to ".env" and fill in your values:  cp .env.example .env
# ============================================================

# --- Authentication ---
# Path to your service-account key JSON (must have Vertex AI User role).
# Alternatively run `gcloud auth application-default login` and leave blank.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# --- Google Cloud project ---
GCP_PROJECT_ID=my-gcp-project-id
GCP_LOCATION=us-central1

# --- GCS bucket used to stage Veo image->video jobs (no gs:// prefix) ---
# Veo reads input images and writes output videos via GCS.
GCS_STAGING_BUCKET=my-stickman-staging-bucket

# --- Model IDs (override only if you have access to other versions) ---
GEMINI_MODEL=gemini-1.5-pro-002
IMAGEN_GENERATE_MODEL=imagen-3.0-generate-002
IMAGEN_CAPABILITY_MODEL=imagen-3.0-capability-001
VEO_MODEL=veo-2.0-generate-001

# --- Generation tuning ---
SCENE_COUNT=5            # number of scenes to break the script into
VIDEO_SECONDS=5          # 4-5s per clip
RETRY_MAX_ATTEMPTS=6     # auto-retry attempts on rate limit / transient errors
RETRY_BASE_DELAY=4       # seconds; exponential backoff base
LOG_LEVEL=INFO
